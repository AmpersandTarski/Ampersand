# Database credentials for Ampersand local testing
# Copy this file to .env and adjust if needed.
# These are the default credentials for the Docker MariaDB container (see docker-compose.yml).
# The Ampersand test runner reads MYSQL_HOST, MYSQL_USER and MYSQL_PASSWORD from the environment.

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
