CONTEXT TestRightResidual IN ENGLISH

PURPOSE CONTEXT TestRightResidual {+ Test right residual operator (\) with proper type checking. +}

PATTERN TestRightResidual

-- Create concept hierarchies to test right residual
CLASSIFY Student ISA Person
CLASSIFY Teacher ISA Person
CLASSIFY Course ISA Topic

-- Basic relations for right residual testing
RELATION enrolled[Student*Course]     -- Student enrolled in Course
RELATION requires[Course*Subject]     -- Course requires Subject
RELATION teaches[Teacher*Subject]     -- Teacher teaches Subject

-- Test relations for results
RELATION competent[Teacher*Subject]   -- Teachers competent in subjects

-- Test 1: Basic right residual with matching sources
-- For r\s, we need join(source(r), source(s)) to exist
-- teaches[Teacher*Subject] \ requires[Course*Subject]
-- source(teaches) = Teacher, source(requires) = Course
-- join(Teacher, Course) exists? NO - they're unrelated
-- This should FAIL
RULE TestRightResidual1: competent = teaches\requires

-- Test 2: Right residual with ISA hierarchy
-- Create a more specific relation to test
RELATION advTeaches[Teacher*Subject]  -- Advanced teacher teaches
CLASSIFY AdvancedTeacher ISA Teacher

-- advTeaches[Teacher*Subject] \ teaches[Teacher*Subject]  
-- source(advTeaches) = Teacher, source(teaches) = Teacher
-- join(Teacher, Teacher) = Teacher ✓
-- result = [target(advTeaches) * target(teaches)] = [Subject * Subject]
RELATION shouldMatch[Subject*Subject]
RULE TestRightResidual2: shouldMatch = advTeaches\teaches

-- Test 3: Right residual with flipped relation
-- teaches[Teacher*Subject] \ teaches~[Subject*Teacher]
-- source(teaches) = Teacher, source(teaches~) = Subject  
-- join(Teacher, Subject) doesn't exist
-- This should FAIL
RULE TestRightResidual3: shouldMatch = teaches\teaches~

-- Test 4: Symmetric test - if sources match, result should be correct
-- Create test relations with matching sources
RELATION proficient[Teacher*Topic]
RELATION specialized[Teacher*Subject]

-- proficient[Teacher*Topic] \ specialized[Teacher*Subject]
-- source(proficient) = Teacher, source(specialized) = Teacher
-- join(Teacher, Teacher) = Teacher ✓
-- result = [target(proficient) * target(specialized)] = [Topic * Subject]
RELATION expertise[Topic*Subject]
RULE TestRightResidual4: expertise = proficient\specialized

ENDPATTERN
ENDCONTEXT
