CONTEXT KleeneTest IN ENGLISH

PURPOSE CONTEXT KleeneTest MARKDOWN
{+ Regression fixture for the Kleene operators, from the plan on issue #1651.
   Population: chain a->b->c->d, branch b->e, redundant shortcut a->c.
   Expected: rRed = r minus (a,c); rPlus = r plus (a,d),(a,e),(b,d);
             rStar = rPlus plus the diagonal.
+}

RELATION r[Node*Node]
POPULATION r CONTAINS
  [ ("a", "b")
  , ("b", "c")
  , ("c", "d")
  , ("b", "e")
  , ("a", "c")
  ]

INTERFACE KleeneDemonstrator LABEL "Kleene demonstrator" :
   "_SESSION"[SESSION] ; V[SESSION*Node]
   CRud BOX<TABLE sortable>
   [ "node"            : I[Node]        cRud
   , "r (editable)"    : r              CRUD
   , "rStar (r*)"      : r*             cRud
   , "rPlus (r+)"      : r+             cRud
   , "rRed (r%)"       : r%             cRud
   ]

-- the acyclicity guard from the plan (documentation idiom)
RULE acyclicR : r+ /\ I |- -V
MEANING "r stays acyclic, the scope in which r% is the transitive reduction."

ENDCONTEXT
