CONTEXT Test IN ENGLISH
  CLASSIFY A ISA AOrB
  CLASSIFY B ISA AOrB

PATTERN Test18
RELATION r[X*Y]
RELATION s[X*A]
RELATION t[A*Y]
RELATION t[B*Y]
RULE Test:r = s;I[A];t
CLASSIFY D IS A/\B
ENDPATTERN

ENDCONTEXT

